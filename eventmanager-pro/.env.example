# PostgreSQL (passt zu docker-compose.yml)
DATABASE_URL="postgresql://eventmanager:eventmanager@localhost:5432/eventmanager?schema=public"

# JWT Secrets - in Produktion durch starke zufällige Werte ersetzen!
# Beispiel zum Generieren:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="CHANGE_ME_access_secret_min_32_chars_long_random"
JWT_REFRESH_SECRET="CHANGE_ME_refresh_secret_min_32_chars_long_random"

# Token-Lebensdauer
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_NAME="EventManager Pro"
APP_URL="http://localhost:3000"

# bcrypt Rounds (min. 12 in Produktion)
BCRYPT_ROUNDS="12"
