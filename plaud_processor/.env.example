# ============================================
# Plaud Audio Processor - Konfiguration
# ============================================
# Diese Datei als .env kopieren und anpassen:
#   copy .env.example .env
#
# WICHTIG: Echten Windows-Benutzernamen verwenden!
#   Ermitteln via: echo %USERNAME%
# ============================================

# --- Audioquelle (mindestens eine konfigurieren) ---

# Option 1: Lokaler Watch-Ordner (Plaud-Aufnahmen)
PLAUD_WATCH_FOLDER=C:\Users\DEIN_BENUTZERNAME\OneDrive\Plaud Aufnahmen

# Option 2: Plaud.ai API Token (alternativ)
# PLAUD_API_TOKEN=

# --- Ausgabe ---

# Ordner fuer PDF-Berichte (OneDrive synchronisiert automatisch)
PDF_OUTPUT_FOLDER=C:\Users\DEIN_BENUTZERNAME\OneDrive\Plaud Berichte

# --- Transkription ---

# Whisper-Modell: tiny | base | small | medium | large
# Groessere Modelle = bessere Qualitaet, aber langsamer
WHISPER_MODEL=medium

# Sprache: de = Deutsch, leer = automatische Erkennung
TRANSCRIPTION_LANGUAGE=de

# --- KI-Analyse (Ollama - KOSTENLOS, bevorzugt) ---

# Ollama-Modell fuer Protokollerstellung
OLLAMA_MODEL=llama3.1:8b

# Ollama-URL (Standard fuer Docker)
# OLLAMA_URL=http://host.docker.internal:11434

# --- Fallback KI (nur wenn Ollama nicht laeuft) ---

# Anthropic API Key fuer Claude Haiku (~0.001 EUR/Aufnahme)
# ANTHROPIC_API_KEY=sk-ant-...

# Claude-Modell
# CLAUDE_MODEL=claude-haiku-4-5

# --- Fallback Transkription (nur wenn lokales Whisper fehlschlaegt) ---

# OpenAI API Key (~0.006 EUR/Minute)
# OPENAI_API_KEY=sk-...

# --- E-Mail-Benachrichtigung (SMTP) ---

# Gmail-Beispiel: App-Passwort unter https://myaccount.google.com/apppasswords erstellen
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=deine@gmail.com
EMAIL_TO=empfaenger@beispiel.de

# Rate-Limit: Maximal 1 E-Mail pro X Minuten (mehrere Berichte werden gebuendelt)
EMAIL_RATE_LIMIT_MINUTES=60

# --- Erweitert ---

# Polling-Intervall in Sekunden (Standard: 300 = 5 Minuten)
# POLL_INTERVAL_SECONDS=300

# Sprecher-Erkennung: Pause in Sekunden fuer Sprecherwechsel
# SPEAKER_PAUSE_THRESHOLD=1.5
