# ============================================================
# Plaud Audio Processor – Konfigurationsvorlage
# Kopiere diese Datei nach .env und passe sie an.
# ============================================================

# --- Audioquelle (mindestens eine Option setzen) ---
# Option A: Lokaler Watch-Ordner (empfohlen)
PLAUD_WATCH_FOLDER=C:\Users\DeinName\OneDrive\Plaud Aufnahmen

# Option B: Plaud.ai API-Token (alternativ zu Watch-Ordner)
# PLAUD_API_TOKEN=dein-plaud-api-token

# --- Ausgabe ---
PDF_OUTPUT_FOLDER=C:\Users\DeinName\OneDrive\Plaud Berichte

# --- Transkription ---
# Modell: tiny | base | small | medium | large
# Empfehlung: medium (gute Balance Qualität/Geschwindigkeit)
WHISPER_MODEL=medium

# Sprache: de | en | fr | ... (leer = automatisch)
TRANSCRIPTION_LANGUAGE=de

# OpenAI API Key (nur als Whisper-Fallback, wenn kein lokales Whisper)
# OPENAI_API_KEY=sk-...

# --- KI-Analyse (Ollama bevorzugt – KOSTENLOS) ---
OLLAMA_MODEL=llama3.1:8b
# OLLAMA_URL=http://host.docker.internal:11434  # Standard, muss nicht geändert werden

# --- Fallback KI: Claude Haiku (~€0.001/Aufnahme) ---
# Nur setzen, wenn Ollama als Fallback nicht ausreicht
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5

# --- E-Mail (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine@gmail.com
# Gmail App-Passwort: Google-Konto → Sicherheit → 2FA → App-Passwörter
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=deine@gmail.com
EMAIL_TO=empfaenger@beispiel.de
# Maximale E-Mail-Frequenz in Minuten (mehrere Berichte werden gebündelt)
EMAIL_RATE_LIMIT_MINUTES=60

# --- Polling-Intervall ---
POLL_INTERVAL_SECONDS=300

# --- Sprecher-Erkennung ---
# Pause in Sekunden, ab der ein Sprecherwechsel angenommen wird
SPEAKER_PAUSE_THRESHOLD=1.5
