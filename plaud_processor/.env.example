# ============================================================
# Plaud Processor – Konfigurationsdatei
# Kopieren nach .env und Werte ausfüllen
# ============================================================

# ------------------------------------------------------------
# Plaud.ai Quelle (mindestens EINE Option konfigurieren)
# ------------------------------------------------------------

# Option A: Plaud.ai API-Token (aus app.plaud.ai → Einstellungen → API)
PLAUD_API_TOKEN=

# Option B: Lokaler Ordner, in den die Plaud-App Aufnahmen exportiert
#           (z. B. via Plaud App → Exportieren → Audiodatei speichern)
PLAUD_WATCH_FOLDER=C:\Users\IhrName\OneDrive\Plaud Aufnahmen

# ------------------------------------------------------------
# PDF-Ausgabe (KOSTENLOS – kein Azure nötig!)
# Einfach einen Ordner angeben, der von OneDrive synchronisiert wird.
# OneDrive Desktop synct den Inhalt automatisch in die Cloud.
# ------------------------------------------------------------
PDF_OUTPUT_FOLDER=C:\Users\IhrName\OneDrive\Plaud Berichte

# ------------------------------------------------------------
# Transkription – OpenAI Whisper API
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...
# Sprache der Aufnahmen (leer = automatisch erkennen)
# Beispiele: de, en, fr, es
TRANSCRIPTION_LANGUAGE=de
# Whisper-Modell (whisper-1 ist Standard)
WHISPER_MODEL=whisper-1

# ------------------------------------------------------------
# KI-Analyse – Anthropic / Claude
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Empfohlen: claude-sonnet-4-6 (schnell + günstig)
# Alternativ: claude-opus-4-6 (höchste Qualität)
CLAUDE_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------
# E-Mail-Benachrichtigung (SMTP)
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ihre-adresse@gmail.com
# Für Gmail: App-Passwort verwenden (nicht das normale Passwort)
# https://myaccount.google.com/apppasswords
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=ihre-adresse@gmail.com
# Empfänger (mehrere mit Komma trennen)
EMAIL_TO=empfaenger@beispiel.de
# Minimaler Abstand zwischen E-Mails in Minuten (Standard: 60)
EMAIL_RATE_LIMIT_MINUTES=60

# ------------------------------------------------------------
# Allgemein
# ------------------------------------------------------------
# Arbeitsverzeichnis für temporäre Dateien und Logs
WORK_DIR=/tmp/plaud_processor
# Polling-Intervall in Sekunden (nur relevant bei --loop)
POLL_INTERVAL_SECONDS=300
